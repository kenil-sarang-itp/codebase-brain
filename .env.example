# =============================================================================
# CodeBase Brain — environment configuration.
#
# Copy this file to `.env` and adjust as needed:
#     cp .env.example .env
#
# EVERY value has a working default. With an empty `.env` the whole stack still
# boots: the app falls back to offline AI providers and a local repository
# source, so you can demo it with ZERO credentials. Fill values in to switch on
# real Vertex AI, Cohere reranking, and GitHub access.
# =============================================================================

# --- Datastore credentials ---------------------------------------------------
# Used by postgres + backend + worker. Defaults are fine for local use.
POSTGRES_USER=codebrain
POSTGRES_PASSWORD=codebrain
POSTGRES_DB=codebrain

# --- Security ----------------------------------------------------------------
# CHANGE THIS for any non-local deployment — it signs the JWT access tokens.
JWT_SECRET_KEY=change-me-in-production
# Allowed browser origins for CORS. The frontend container is served on :8080.
CORS_ORIGINS=http://localhost:8080
# Shared secret GitHub uses to sign webhook payloads (see /api/webhook).
GITHUB_WEBHOOK_SECRET=local-webhook-secret

# --- AI providers ------------------------------------------------------------
# Leave ALL of these blank to run with the offline fallback providers (the app
# boots and is fully navigable; answers are clearly-labelled placeholders).
#
# For REAL answers, provide Google Vertex AI access. A single GCP service
# account covers BOTH Gemini (LLM) and text-embedding-004 (embeddings):
#   1. Set GCP_PROJECT_ID to your project.
#   2. Put the service-account JSON key at ./secrets/gcp-sa.json
#      (the backend/worker containers mount ./secrets to /secrets read-only).
# Alternatively, set GOOGLE_API_KEY to use a Gemini API key instead of Vertex.
GCP_PROJECT_ID=
GCP_LOCATION=
GOOGLE_GENAI_USE_VERTEXAI="True"
GOOGLE_API_KEY=
# Directory mounted to /secrets in the containers (holds gcp-sa.json).
GCP_CREDENTIALS_DIR=./secrets

# Model selection — both are env-configurable. The spec's gemini-1.5-pro is
# deprecated, so the default is a current model.
LLM_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=text-embedding-004

# Cohere powers the rerank stage of retrieval. Blank => local Jaccard reranker.
COHERE_API_KEY=

# --- Repository source -------------------------------------------------------
# "local"      — index a directory mounted into the container (zero setup).
# "github_mcp" — index a real GitHub repo via the official GitHub MCP server.
REPO_SOURCE=github_mcp

# When REPO_SOURCE=local: the host directory to index, mounted to /repo.
LOCAL_REPO_MOUNT=./sample-repo
CORS_ORIGINS=http://localhost:8080

# When REPO_SOURCE=github_mcp: the repo to index and a token to read it.
GITHUB_REPO=
GITHUB_TOKEN=
# Transport for the GitHub MCP server: "stdio" (default compose setup) or
# "http" (a long-running github-mcp-server HTTP container).
GITHUB_MCP_TRANSPORT=http
GITHUB_MCP_URL=http://github-mcp:8080/mcp
# --- Observability -----------------------------------------------------------
# Phoenix runs as its own container; the API/workers send traces to it.
TRACING_ENABLED=true
