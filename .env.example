# App
APP_NAME=CodeBase Brain
ENVIRONMENT=local
DEBUG=true

# PostgreSQL
POSTGRES_USER=codebrain
POSTGRES_PASSWORD=codebrain
POSTGRES_DB=codebrain
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=codebase_knowledge
EMBEDDING_DIM=768

# Security
JWT_SECRET_KEY=change-me-in-production

# AI Providers (leave empty to use local offline fallbacks)
GOOGLE_API_KEY=
GCP_PROJECT_ID=
COHERE_API_KEY=
